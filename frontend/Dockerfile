# syntax=docker/dockerfile:1.7

FROM node:20-alpine AS deps
WORKDIR /app

COPY package*.json ./
RUN npm install --include=optional --no-audit --no-fund

FROM deps AS builder
WORKDIR /app

ARG REACT_APP_API_BASE
ARG REACT_APP_COGNITO_AUTHORITY
ARG REACT_APP_COGNITO_CLIENT_ID
ARG REACT_APP_COGNITO_DOMAIN
ARG REACT_APP_OIDC_REDIRECT_URI
ARG REACT_APP_OIDC_SCOPE
ARG REACT_APP_LOGOUT_URI

ENV REACT_APP_API_BASE=$REACT_APP_API_BASE
ENV REACT_APP_COGNITO_AUTHORITY=$REACT_APP_COGNITO_AUTHORITY
ENV REACT_APP_COGNITO_CLIENT_ID=$REACT_APP_COGNITO_CLIENT_ID
ENV REACT_APP_COGNITO_DOMAIN=$REACT_APP_COGNITO_DOMAIN
ENV REACT_APP_OIDC_REDIRECT_URI=$REACT_APP_OIDC_REDIRECT_URI
ENV REACT_APP_OIDC_SCOPE=$REACT_APP_OIDC_SCOPE
ENV REACT_APP_LOGOUT_URI=$REACT_APP_LOGOUT_URI

COPY . .
RUN npm run build

FROM nginx:1.27-alpine AS runtime

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
